/*@ define:module:header
hidden: true
name: header
*/
meta { name = "General Filter"; description = "Yeah..."; }

//-------------------------------NOTES-------------------------------------//

/*
 Modules are just for the website UI and are not necesary for function.
 actual funtion is done with rules/apply.
 Syntax is rule|apply (conditions) { things }
 Rules, if applicable to the item, will apply the effects to the item and then stop checking for additional rules. apply will apply the effects and then allow subsequent rules to still run.
 
 In a #define, (_) means it's a function that has 1 input but no name because we won't use it. The part after (_) can be anything it returns. A rule for example. If you want inputs it's normal (input1, input2), etc.
 In ownership, a macro returns a boolean that checks if acct type is non-iron (0) or if ownership is not a drop for another player (2). As far as I can tell,
 acctType = 
  0 -> main
  1 -> iron
  2 -> group iron
 ownership is in the docs and 2 = drop for another player.
*/


//---------------------------GENERAL SETTINGS------------------------------//



/*@ define:module:general_settings
name: General Settings
description: |
    Global settings to apply to filter rules. These are defaults that will apply to anything not matching any of the other rules. Custom highlight group items will NOT have any additional filtering applied and will always show.
*/


#define CONST_TAKEABLE(_) (accountType:0 || !ownership:2)

/*@ define:input:ownership
type: boolean
group: Ownership Filtering
label: Show only takeable items (no effect if main account)
*/
#define VAR_GLOBAL_OWNERSHIP_TAKEABLE true

/*@ define:input:ownership
type: stringlist
group: Ownership Filtering
label: Ignore ownership rules item list
*/
#define VAR_GLOBAL_OWNERSHIP_IGNORES ["Dawnbringer"]
/*
 Apply ownership rules. If not takeable and not an ignored item, hide it.
 must still pass an input to the macro even if not used.
 name: accepts lists, so this checks if name is not in the list
*/
rule (!CONST_TAKEABLE(0) && !name:VAR_GLOBAL_OWNERSHIP_IGNORES) {
    hidden=true;
}

/*@ define:input:default_style
type: style
group: Default Style
label: Default Style
*/
#define VAR_GLOBAL_STYLE hidden = false;
// Global style, always apply it. It can be overridden later.
apply (true) { VAR_GLOBAL_STYLE }

/*@ define:input:custom_highlight_group
type: stringlist
group: Custom Highlight Group
label: Items to highlight
*/
#define VAR_GLOBAL_CUST_HIGHLIGHT_ITEMS []

/*@ define:input:custom_highlight_group
type: style
group: Custom Highlight Group
label: Custom Highlight Group
*/
#define VAR_GLOBAL_CUST_HIGHLIGHT_STYLE hidden = false;textColor = "#ffe01212";
// Apply custom highlight using rule so additional rules are skipped.
rule (name:VAR_GLOBAL_CUST_HIGHLIGHT_ITEMS) {
    VAR_GLOBAL_CUST_HIGHLIGHT_STYLE 
}

//-------------------------Rune Filtering----------------------------//

#define RUNE_TYPES ["Air rune", "Water rune", "Earth rune", "Fire rune", "Mist rune", "Dust rune", "Mud rune",     "Smoke rune", "Steam rune", "Lava rune", "Sunfire rune", "Body rune", "Mind rune", "Chaos rune", "Cosmic rune",     "Nature rune", "Law rune", "Death rune", "Blood rune", "Soul rune", "Aether rune", "Wrath rune"]


