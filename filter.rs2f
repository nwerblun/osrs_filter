//-------------------------Misc stuff----------------------------//

/*@ define:module:misc_stuff
---
name: Misc Stuff
*/
//coords are x0,y0,z0,x1,y1,z1 where 0 = lower left, 1 = upper right
#define CONST_CHAOS_ALTAR_LOC [2946,3816,0,2957,3825,0]
/*@ define:input
type: boolean
label: show wine of zammy in chaos altar?
*/
#define VAR_MISC_STUFF_SHOW_WOZ true
apply (area:CONST_CHAOS_ALTAR_LOC && name:["Wine of zamorak"] && VAR_MISC_STUFF_SHOW_WOZ) { hidden = false; }
