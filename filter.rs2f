#define VAR_COINS_MED_SHOW 20000
/*@ define:input
type: style
label: Style
group: Medium Tier
exampleItem: Coins
*/
#define VAR_COINS_MED_STYLE hidden = false;textColor = "#ffd0db10";backgroundColor = "#3bfffb00";textAccent = 1;
/*@ define:input
type: number
group: Minimum Tier
label: Must exceed
*/
#define VAR_COINS_MIN_SHOW 1000
/*@ define:input
type: style
label: Style
group: Minimum Tier
exampleItem: Coins
*/
#define VAR_COINS_MIN_STYLE hidden = false;textColor = "#ffd0db10";textAccent = 1;


rule (name:["coins"] && quantity:>=VAR_COINS_INSANE_SHOW) { VAR_COINS_INSANE_STYLE }
rule (name:["coins"] && quantity:>=VAR_COINS_EXT_SHOW) { VAR_COINS_EXT_STYLE }
rule (name:["coins"] && quantity:>=VAR_COINS_HIGH_SHOW) { VAR_COINS_HIGH_STYLE }
rule (name:["coins"] && quantity:>=VAR_COINS_MED_SHOW) { VAR_COINS_MED_STYLE }
rule (name:["coins"] && quantity:>=VAR_COINS_MIN_SHOW) { VAR_COINS_MIN_STYLE }


//---------------------------Uniques------------------------------//



/*@ define:module:uniques
---
name: Uniques
description: |
    Highlighting for unique items with 3 tiers
*/
/*@ define:input
type: stringlist
group: High Tier
label: Items to highlight
*/
#define VAR_UNIQUE_ITEMS_HIGH ["Infernal cape","Fire cape","Dizana's quiver*","Ancient blood ornament kit","Ultor vestige","Venator vestige","Bellator vestige","Magus vestige","Executioner's axe head","Leviathan's lure","Siren's staff","Eye of the duke","Purifying sigil"]
/*@ define:input
type: style
label: Style
group: High Tier
exampleItem: Executioner's Axe Head
*/
#define VAR_UNIQUE_STYLE_HIGH hidden = false;textColor = "#ff0000";backgroundColor = "#ffffffff";borderColor = "#ff0000";lootbeamColor = "#ffffffff";textAccent = 1;fontType = 3;showLootbeam = true;showValue = true;
/*@ define:input
type: stringlist
group: Medium Tier
label: Items to highlight
*/
#define VAR_UNIQUE_ITEMS_MED ["Larran's key","Brimstone key","Jar of *","Noxious pommel","Noxious point","Noxious blade"]
/*@ define:input
type: style
label: Style
group: Medium Tier
exampleItem: Brimstone Key
*/
#define VAR_UNIQUE_STYLE_MED hidden = false;textColor = "#ffffffff";backgroundColor = "#af6025";borderColor = "#ffffffff";textAccent = 3;showValue = true;
/*@ define:input
type: stringlist
group: Low Tier
label: Items to highlight
*/
#define VAR_UNIQUE_ITEMS_LOW ["brittle key","mossy key","giant key","ecumenical key","abyssal head","araxyte head","alchemical hydra heads","kbd heads","kq head*","dark claw","bludgeon claw","bludgeon spine","bludgeon axon","hydra's eye","hydra's fang","hydra's heart","strangled tablet","scarred tablet","sirenic tablet","frozen tablet","scurrius' spine","vorkath's head"]
/*@ define:input
type: style
label: Style
group: Low Tier
exampleItem: Vorkath's head
*/
#define VAR_UNIQUE_STYLE_LOW hidden = false;textColor = "#ff000000";backgroundColor = "#af6025";borderColor = "#ff000000";textAccent = 3;showValue = true;

rule (name:VAR_UNIQUE_ITEMS_HIGH) { VAR_UNIQUE_STYLE_HIGH }
rule (name:VAR_UNIQUE_ITEMS_MED) { VAR_UNIQUE_STYLE_MED }
rule (name:VAR_UNIQUE_ITEMS_LOW) { VAR_UNIQUE_STYLE_LOW }

//-------------------------Untradeables----------------------------//



/*@ define:module:untradeables
---
name: Untradeables
description: |
    Value to show is only used if "always show untradeables" is not enabled. Only items that exceed that value will be shown. They will only be styled if they are included in the highlighted items list.
*/
/*@ define:input
type: boolean
label: Always show untradeables
*/
#define VAR_UNTRADEABLE_ALWAYS_SHOW true

/*@ define:input
type: boolean
label: Show item icon in menu
*/
#define VAR_UNTRADEABLE_SHOW_ICON true

/*@ define:input
type: number
label: Value to show
*/
#define VAR_UNTRADEABLE_MIN_VAL 0

/*@ define:input
type: boolean
label: Prioritize untradeables
*/
#define VAR_UNTRADEABLE_PRIORITIZE true

/*@ define:input
type: stringlist
label: Items to highlight
group: Highighted items
*/
#define VAR_UNTRADEABLES_HIGHLIGHTED ["Dark totem*","Ancient shard","Ancient shard"]

/*@ define:input
type: style
label: Style
group: Highighted items
exampleItem: Dragon Defender
*/
#define VAR_UNTRADEABLES_STYLE hidden = false;textColor = "#af6025";backgroundColor = "#350d0d";borderColor = "#af6025";textAccent = 3;showLootbeam = false;showValue = false;highlightTile = false;

apply (tradeable:false && VAR_UNTRADEABLE_SHOW_ICON) { icon = CurrentItem(); }
apply (tradeable:false && name:VAR_UNTRADEABLES_HIGHLIGHTED) { VAR_UNTRADEABLES_STYLE }
rule (!VAR_UNTRADEABLE_ALWAYS_SHOW && value:<VAR_UNTRADEABLE_MIN_VAL) {
    hidden = true;
}
rule (tradeable:false && VAR_UNTRADEABLE_PRIORITIZE) {
    menuSort = -1;
}


//-------------------------Item Values----------------------------//




/*@ define:module:item_values
---
name: Item values
*/

/*@ define:input:item_values
type: number
label: Value
group: 'Insane tier++'
*/
#define VAR_VALUE_T5_VALUE 100000000

/*@ define:input:item_values
type: number
label: Value
group: 'Insane tier+'
*/
#define VAR_VALUE_T4_VALUE 50000000

/*@ define:input:item_values
type: number
label: Value
group: Insane tier
*/
#define VAR_VALUE_T3_VALUE 10000000

/*@ define:input:item_values
type: number
label: Value
group: High tier
*/
#define VAR_VALUE_T2_VALUE 1000000

/*@ define:input:item_values
type: number
label: Value
group: Medium tier
*/
#define VAR_VALUE_T1_VALUE 100000

/*@ define:input:item_values
type: number
label: Value
group: Low tier
*/
#define VAR_VALUE_T0_VALUE 10000

/*@ define:input:item_values
type: style
label: Style
group: 'Insane tier++'
exampleItem: Torva platebody (damaged)
*/
#define VAR_VALUE_T5_CUSTOMSTYLE hidden = false;textColor = "#ff0000";backgroundColor = "#ffffff";borderColor = "#ff0000";textAccent = 3;showLootbeam = true;showValue = true;highlightTile = false;

/*@ define:input:item_values
type: style
label: Style
group: 'Insane tier+'
exampleItem: Zaryte vambraces
*/
#define VAR_VALUE_T4_CUSTOMSTYLE hidden = false;textColor = "#ffffff";backgroundColor = "#80ff0000";borderColor = "#ffffff";lootbeamColor = "#ff0000";showLootbeam = true;showValue = true;highlightTile = false;

/*@ define:input:item_values
type: style
label: Style
group: Insane tier
exampleItem: Bandos tassets
*/
#define VAR_VALUE_T3_CUSTOMSTYLE hidden = false;textColor = "#ff66b2";backgroundColor = "#80ffffff";borderColor = "#ff66b2";textAccent = 4;showLootbeam = true;showValue = true;highlightTile = false;

/*@ define:input:item_values
type: style
label: Style
group: High tier
exampleItem: Abyssal whip
*/
#define VAR_VALUE_T2_CUSTOMSTYLE hidden = false;textColor = "#ff9600";backgroundColor = "#80ffffff";borderColor = "#ff9600";textAccent = 4;showLootbeam = true;showValue = true;highlightTile = false;

/*@ define:input:item_values
type: style
label: Style
group: Medium tier
exampleItem: Dragon pickaxe
*/
#define VAR_VALUE_T1_CUSTOMSTYLE hidden = false;textColor = "#99ff99";borderColor = "#99ff99";showValue = true;highlightTile = false;

/*@ define:input:item_values
type: style
label: Style
group: Low tier
exampleItem: Rune platebody
*/
#define VAR_VALUE_T0_CUSTOMSTYLE hidden = false;textColor = "#66b2ff";showValue = true;highlightTile = false;

rule (value:>=VAR_VALUE_T5_VALUE) { VAR_VALUE_T5_CUSTOMSTYLE }
rule (value:>=VAR_VALUE_T4_VALUE) { VAR_VALUE_T4_CUSTOMSTYLE }
rule (value:>=VAR_VALUE_T3_VALUE) { VAR_VALUE_T3_CUSTOMSTYLE }
rule (value:>=VAR_VALUE_T2_VALUE) { VAR_VALUE_T2_CUSTOMSTYLE }
rule (value:>=VAR_VALUE_T1_VALUE) { VAR_VALUE_T1_CUSTOMSTYLE }
rule (value:>=VAR_VALUE_T0_VALUE) { VAR_VALUE_T0_CUSTOMSTYLE }
apply (value:<VAR_VALUE_T0_VALUE) { hidden = true; }
// unhide untradeables if set to
apply (tradeable:false && VAR_UNTRADEABLE_ALWAYS_SHOW) [ hidden = false; ]
//-------------------------Always Show----------------------------//



/*@ define:module:always_show
---
name: Always show
*/

/*@ define:input
type: stringlist
label: item list
*/
#define VAR_ALWAYS_SHOW_ITEMS ["Prayer potion*","Super restore*","Saradomin brew*","Shark","Manta Ray","Anglerfish","Stamina potion*","*Super combat*","*Ranging potion*","Loop half*","Tooth half*","Blighted*","*teleport","Blighted*","*teleport"]

rule (name:VAR_ALWAYS_SHOW_ITEMS) { hidden = false; }

//-------------------------Rune Filtering pt 2--------------------------//

// Apply rune stuff again to unhide them if not ignoring item value, but they do exceed the hide qty
apply (name:["Air rune"] && quantity:>=VAR_RUNE_AIR_HIDE_QTY) { hidden = false; }
