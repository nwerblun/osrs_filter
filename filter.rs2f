apply (name:["Fire rune"] && quantity:<VAR_RUNE_FIRE_HIDE_QTY) { hidden = true; }
apply (name:["Smoke rune"] && quantity:<VAR_RUNE_SMOKE_HIDE_QTY) { hidden = true; }
