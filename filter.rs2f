apply (name:["Mind rune"] && quantity:<VAR_RUNE_MIND_HIDE_QTY) { hidden = true; }
apply (name:["Cosmic rune"] && quantity:<VAR_RUNE_COSMIC_HIDE_QTY) { hidden = true; }
apply (name:["Chaos rune"] && quantity:<VAR_RUNE_CHAOS_HIDE_QTY) { hidden = true; }
apply (name:["Nature rune"] && quantity:<VAR_RUNE_NATURE_HIDE_QTY) { hidden = true; }
apply (name:["Law rune"] && quantity:<VAR_RUNE_LAW_HIDE_QTY) { hidden = true; }
apply (name:["Death rune"] && quantity:<VAR_RUNE_DEATH_HIDE_QTY) { hidden = true; }
apply (name:["Blood rune"] && quantity:<VAR_RUNE_BLOOD_HIDE_QTY) { hidden = true; }
apply (name:["Soul rune"] && quantity:<VAR_RUNE_SOUL_HIDE_QTY) { hidden = true; }
apply (name:["Aether rune"] && quantity:<VAR_RUNE_AETHER_HIDE_QTY) { hidden = true; }
apply (name:["Wrath rune"] && quantity:<VAR_RUNE_WRATH_HIDE_QTY) { hidden = true; }
// If ignore values, stop processing additional rules
rule (name:RUNE_TYPES && VAR_RUNE_IGNORE_VALUES) {}

