//-------------------------Clues----------------------------//




/*@ define:module:clues
---
name: Clues
description: |
  Styles apply to the following items:

  * Clue scrolls
  * Scroll boxes
  * Challenge scrolls
  * Reward caskets
*/

/*@ define:input:clues
type: style
label: Beginner clue
*/
#define VAR_CLUE_BEGINNER_CUSTOMSTYLE hidden = false;textColor = "#ffffff";backgroundColor = "#beb287";borderColor = "#ffffff";menuTextColor = "#ffe0e0e0";

/*@ define:input:clues
type: style
label: Easy clue
*/
#define VAR_CLUE_EASY_CUSTOMSTYLE hidden = false;textColor = "#00ff00";backgroundColor = "#beb287";borderColor = "#00ff00";menuTextColor = "#29802d";

/*@ define:input:clues
type: style
label: Medium clue
*/
#define VAR_CLUE_MEDIUM_CUSTOMSTYLE hidden = false;textColor = "#00ffff";backgroundColor = "#beb287";borderColor = "#00ffff";menuTextColor = "#569699";

/*@ define:input:clues
type: style
label: Hard clue
*/
#define VAR_CLUE_HARD_CUSTOMSTYLE hidden = false;textColor = "#ff00ff";backgroundColor = "#beb287";borderColor = "#ff00ff";menuTextColor = "#833798";

/*@ define:input:clues
type: style
label: Elite clue
*/
#define VAR_CLUE_ELITE_CUSTOMSTYLE hidden = false;textColor = "#ffff00";backgroundColor = "#beb287";borderColor = "#ffff00";menuTextColor = "#bda518";

/*@ define:input:clues
type: style
label: Master clue
*/
#define VAR_CLUE_MASTER_CUSTOMSTYLE hidden = false;textColor = "#ff0000";backgroundColor = "#beb287";borderColor = "#ff0000";menuTextColor = "#9b3026";


rule (name:["scroll box (beginner)", "clue scroll (beginner)", "reward casket (beginner)", "challenge scroll (beginner)"]) {
  VAR_CLUE_BEGINNER_CUSTOMSTYLE
}
rule (name:["scroll box (easy)", "clue scroll (easy)", "reward casket (easy)", "challenge scroll (easy)"]) {
  VAR_CLUE_EASY_CUSTOMSTYLE
}
rule (name:["scroll box (medium)", "clue scroll (medium)", "reward casket (medium)", "challenge scroll (medium)"]) {
  VAR_CLUE_MEDIUM_CUSTOMSTYLE
}
rule (name:["scroll box (hard)", "clue scroll (hard)", "reward casket (hard)", "challenge scroll (hard)"]) {
  VAR_CLUE_HARD_CUSTOMSTYLE
}
rule (name:["scroll box (elite)", "clue scroll (elite)", "reward casket (elite)", "challenge scroll (elite)"]) {
  VAR_CLUE_ELITE_CUSTOMSTYLE
}
rule (name:["scroll box (master)", "clue scroll (master)", "reward casket (master)", "challenge scroll (master)"]) {
  VAR_CLUE_MASTER_CUSTOMSTYLE
}


//-------------------------Herbs----------------------------//




/*@ define:module:herbs
---
name: Herbs
description: |
  Handles both grimy and cleaned herbs.
  
  These rules apply to unnoted herbs only. Noted ones will fallthrough to value
  rules.
*/

#define CONST_HERB_HERBS [  "*guam leaf",  "*marrentill",  "*tarromin",  "*harralander",  "*ranarr weed",  "*toadflax",  "*irit leaf",  "*avantoe",  "*kwuarm",  "*huasca",  "*snapdragon",  "*cadantine",  "*lantadyme",  "*dwarf weed",  "*torstol",]

#define CONST_HERB_DEFAULTCOLOR GREEN

/*@ define:input:herbs
type: number
label: Minimum cash value
*/
#define VAR_HERB_MINVALUE 5000

/*@ define:input:herbs
type: enumlist
label: Always show
enum: [
  {"label":"Guam leaf","value":"*guam leaf"},
  {"label":"Marrentill","value":"*marrentill"},
  {"label":"Tarromin","value":"*tarromin"},
  {"label":"Harralander","value":"*harralander"},
  {"label":"Ranarr weed","value":"*ranarr weed"},
  {"label":"Toadflax","value":"*toadflax"},
  {"label":"Irit leaf","value":"*irit leaf"},
  {"label":"Avantoe","value":"*avantoe"},
  {"label":"Kwuarm","value":"*kwuarm"},
  {"label":"Huasca","value":"*huasca"},
  {"label":"Snapdragon","value":"*snapdragon"},
  {"label":"Cadantine","value":"*cadantine"},
  {"label":"Lantadyme","value":"*lantadyme"},
  {"label":"Dwarf weed","value":"*dwarf weed"},
  {"label":"Torstol","value":"*torstol"}
]
*/
#define VAR_HERB_SHOW ["*ranarr weed","*huasca","*snapdragon"]

/*@ define:input:herbs
type: enumlist
label: Always hide
enum: [
  {"label":"Guam leaf","value":"*guam leaf"},
  {"label":"Marrentill","value":"*marrentill"},
  {"label":"Tarromin","value":"*tarromin"},
  {"label":"Harralander","value":"*harralander"},
  {"label":"Ranarr weed","value":"*ranarr weed"},
  {"label":"Toadflax","value":"*toadflax"},
  {"label":"Irit leaf","value":"*irit leaf"},
  {"label":"Avantoe","value":"*avantoe"},
  {"label":"Kwuarm","value":"*kwuarm"},
  {"label":"Huasca","value":"*huasca"},
  {"label":"Snapdragon","value":"*snapdragon"},
  {"label":"Cadantine","value":"*cadantine"},
  {"label":"Lantadyme","value":"*lantadyme"},
  {"label":"Dwarf weed","value":"*dwarf weed"},
  {"label":"Torstol","value":"*torstol"}
]
*/
#define VAR_HERB_HIDE ["*guam leaf","*marrentill","*tarromin"]

/*@ define:input:herbs
type: style
label: Style
exampleItem: Grimy torstol
*/
#define VAR_HERB_CUSTOMSTYLE hidden = false;textColor = "#00ff00";

apply (noted:false && name:CONST_HERB_HERBS) { VAR_HERB_CUSTOMSTYLE }

apply (noted:false && name:CONST_HERB_HERBS && value:<VAR_HERB_MINVALUE) { hidden = true; }

rule (noted:false && name:VAR_HERB_SHOW) { hidden = false; }
rule (noted:false && name:VAR_HERB_HIDE) { hidden = true; }
// stop processing additional rules for herbs
rule (noted:false && name:CONST_HERB_HERBS) {}

